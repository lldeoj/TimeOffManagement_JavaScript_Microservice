# Publisher API Environment Variables
NODE_ENV=production
PORT=3000
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
MONGODB_URL=mongodb://admin:password@mongodb:27017/time_off?authSource=admin
CORS_ORIGIN=*

